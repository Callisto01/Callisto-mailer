{
    "name": "callisto/callisto-mailer",
    "description": "A private Symfony bundle to manage and send emails dynamically using database-stored templates and premium layouts.",
    "type": "symfony-bundle",
    "license": "proprietary",
    "authors": [
        {
            "name": "Callisto Team",
            "email": "contact@callisto.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "symfony/framework-bundle": "^7.0|^8.0",
        "symfony/mailer": "^7.0|^8.0",
        "symfony/twig-bundle": "^7.0|^8.0",
        "symfony/mime": "^7.0|^8.0",
        "symfony/yaml": "^7.0|^8.0",
        "doctrine/doctrine-bundle": "^2.12|^3.0",
        "doctrine/orm": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/browser-kit": "^7.0|^8.0",
        "symfony/css-selector": "^7.0|^8.0",
        "symfony/phpunit-bridge": "^7.0|^8.0"
    },
    "autoload": {
        "psr-4": {
            "Callisto\\CallistoMailer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Callisto\\CallistoMailer\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
