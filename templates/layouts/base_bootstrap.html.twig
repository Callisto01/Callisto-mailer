<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ subject|default('') }}</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            width: 100% !important;
            height: 100% !important;
            background-color: #f8f9fa;
            font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            -webkit-font-smoothing: antialiased;
            text-size-adjust: 100%;
        }
        table {
            border-collapse: separate;
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
            width: 100%;
        }
        td {
            font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
            font-size: 16px;
            vertical-align: top;
            color: #212529;
            line-height: 1.6;
        }
        a {
            color: #0d6efd;
            text-decoration: none;
        }
        a:hover {
            text-decoration: underline;
        }
        .btn-primary {
            background-color: #0d6efd;
            border: solid 1px #0d6efd;
            border-radius: 0.375rem;
            color: #ffffff !important;
            display: inline-block;
            font-size: 16px;
            font-weight: 500;
            line-height: 1.5;
            padding: 0.5rem 1rem;
            text-decoration: none;
        }
        .btn-primary:hover {
            background-color: #0b5ed7;
            border-color: #0a58ca;
        }
    </style>
</head>
<body style="background-color: #f8f9fa; font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif; margin: 0; padding: 0;">
    <table role="presentation" border="0" cellpadding="0" cellspacing="0" style="background-color: #f8f9fa; width: 100%;">
        <tr>
            <td>&nbsp;</td>
            <td class="container" style="display: block; margin: 0 auto !important; max-width: 600px; padding: 20px; width: 600px;">
                <div class="content" style="box-sizing: border-box; display: block; margin: 0 auto; max-width: 600px; padding: 10px;">
                    
                    <!-- Header -->
                    <table role="presentation" border="0" cellpadding="0" cellspacing="0" style="margin-bottom: 20px; width: 100%;">
                        <tr>
                            <td align="center" style="padding: 10px 0;">
                                <span style="font-size: 24px; font-weight: 700; color: #0d6efd; letter-spacing: -0.5px;">Callisto</span>
                            </td>
                        </tr>
                    </table>

                    <!-- Card wrapper -->
                    <table role="presentation" class="main" style="background: #ffffff; border: 1px solid #dee2e6; border-radius: 0.375rem; width: 100%; border-spacing: 0; box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);">
                        <tr>
                            <!-- Colored top bar -->
                            <td style="background-color: #0d6efd; height: 4px; line-height: 4px; padding: 0; border-top-left-radius: 0.375rem; border-top-right-radius: 0.375rem;">
                                &nbsp;
                            </td>
                        </tr>
                        <tr>
                            <td class="wrapper" style="box-sizing: border-box; padding: 30px; font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;">
                                <table role="presentation" border="0" cellpadding="0" cellspacing="0" style="width: 100%;">
                                    <tr>
                                        <td>
                                            <!-- Content dynamically compiled from database template -->
                                            {{ content|raw }}
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <!-- Footer -->
                    <table role="presentation" border="0" cellpadding="0" cellspacing="0" style="margin-top: 20px; width: 100%;">
                        <tr>
                            <td align="center" style="color: #6c757d; font-size: 12px; padding: 10px 0; text-align: center; line-height: 1.5;">
                                <p style="margin: 0 0 10px 0;">© {{ "now"|date("Y") }} Callisto. Tous droits réservés.</p>
                                <p style="margin: 0;">Cet email a été envoyé automatiquement. Vous recevez ce message car vous êtes inscrit sur notre plateforme.</p>
                            </td>
                        </tr>
                    </table>

                </div>
            </td>
            <td>&nbsp;</td>
        </tr>
    </table>
</body>
</html>
